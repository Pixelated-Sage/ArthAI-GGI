# FinPredict AI Environment Variables Template
# Copy this file to .env and fill in the values

# --- Database (PostgreSQL / TimescaleDB) ---
# Format: postgresql://user:password@host:port/dbname
TIMESCALEDB_URL=postgresql://user:password@host:port/dbname

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# --- API Keys ---
# Alpha Vantage (Stock Data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# News API (Sentiment)
NEWS_API_KEY=your_news_api_key
# Google Gemini (Reasoning/Chatbot)
Gemini_API_KEY=your_gemini_api_key

# --- Backend Configuration (Optional overrides) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# ML_SERVER_URL=http://localhost:8001
